{
  "name": "OCP Solutions Enterprise Tier Theme",
  "dataColors": [
    "#0A2540",
    "#D97706",
    "#059669",
    "#DC2626",
    "#2563EB",
    "#0D9488",
    "#7C3AED",
    "#475569"
  ],
  "background": "#F8FAFC",
  "foreground": "#0A2540",
  "tableAccent": "#0A2540",
  "textClasses": {
    "callout": {
      "fontSize": 24,
      "fontFace": "Segoe UI Semibold",
      "color": "#0A2540"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#0A2540"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#475569"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#475569"
    }
  },
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "solid": {
              "color": "#F1F5F9"
            },
            "transparency": 0
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#0A2540"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "border": true
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "border": true
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#CBD5E1"
              }
            },
            "radius": 6
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "visualTooltip": [
          {
            "titleFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "background": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "transparency": 10
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "angle": 90,
            "blur": 8,
            "distance": 2,
            "transparency": 12
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "header": [
          {
            "fontColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "show": true,
            "textSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ],
        "values": [
          {
            "backColorSecondary": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontColor": {
              "solid": {
                "color": "#334155"
              }
            },
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "rowHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "backColorSecondary": {
              "solid": {
                "color": "#F8FAFC"
              }
            }
          }
        ]
      }
    },
    "scatterChart": {
      "*": {
        "categoryAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ],
        "valueAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "valueAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "gridlineShow": true,
            "gridlineStyle": "dotted",
            "gridlineColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            }
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "categoryAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "valueAxis": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "labelColor": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "gridlineShow": true,
            "gridlineStyle": "dotted",
            "gridlineColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryAxis": [
          {
            "color": {
              "solid": {
                "color": "#64748B"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Right",
            "labelColor": {
              "solid": {
                "color": "#0A2540"
              }
            },
            "fontFamily": "Segoe UI"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    }
  }
}
